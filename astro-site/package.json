    "deploy": "npm run build && wrangler deploy",
    "astro": "astro",
    "lint": "eslint ."
  },
  "dependencies": {
    "@astrojs/react": "5.0.7",
    "@astrojs/sitemap": "3.7.3",
    "astro": "6.4.8",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@eslint/js": "10.0.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "10.5.0",
    "eslint-plugin-astro": "1.7.0",
    "globals": "17.4.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "wrangler": "4.102.0"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "yaml-language-server": {
      "yaml": "2.8.3"
    }
  }
}
