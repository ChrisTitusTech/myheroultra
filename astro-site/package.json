{
  "name": "myheroultra",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "check": "astro check",
    "generate:tier-preview": "node scripts/generate-tier-preview.mjs",
    "validate": "npm run lint && npm run build && wrangler deploy --dry-run",
