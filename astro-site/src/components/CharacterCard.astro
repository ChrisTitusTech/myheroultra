---
import RoleBadge from './RoleBadge.astro';
import type { CharacterRecord } from '../data/characters';

interface Props {
  character: CharacterRecord;
}
const { character } = Astro.props;
---
<article class="card">
  <div class="card__topline">
    <RoleBadge role={character.role} />
    <span class="difficulty">Difficulty {character.stats.difficulty}/10</span>
  </div>
  <h2><a href={`/characters/${character.slug}`}>{character.name}</a></h2>
  <p>{character.summary}</p>
  <dl class="card__stats">
    <div><dt>HP</dt><dd>{character.stats.hp}</dd></div>
    <div><dt>Mobility</dt><dd>{character.stats.mobility}/10</dd></div>
    <div><dt>Difficulty</dt><dd>{character.stats.difficulty}/10</dd></div>
  </dl>
</article>
