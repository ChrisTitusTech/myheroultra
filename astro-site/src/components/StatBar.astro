---
interface Props {
  label: string;
  value: number;
  max?: number;
  note?: string;
}
const { label, value, max = 10, note } = Astro.props;
const width = Math.max(0, Math.min(100, (value / max) * 100));
---
<div class="stat-bar">
  <div class="stat-bar__label"><span>{label}</span><strong>{value}</strong></div>
  <div
    class="stat-bar__track"
    role="meter"
    aria-label={label}
    aria-valuemin="0"
    aria-valuemax={max}
    aria-valuenow={value}
  >
    <span style={`width: ${width}%`}></span>
  </div>
  {note && <small class="stat-bar__note">{note}</small>}
</div>
