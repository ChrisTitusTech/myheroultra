---
import { site } from '../data/site';
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title={site.title} description={site.description}>
  <section class="hero">
    <p class="eyebrow">Unofficial player field notes</p>
    <h1>{site.title}</h1>
    <p class="hero__lede">Clear character breakdowns, practical guides, and beginner resources built for quick answers between matches.</p>
    <a class="button" href="/characters">Browse Characters</a>
  </section>
</BaseLayout>
