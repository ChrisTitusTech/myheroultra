---
import CharacterLayout from '../../layouts/CharacterLayout.astro';
import { characters, getCharacterBySlug } from '../../data/characters';

export function getStaticPaths() {
  return characters.map((character) => ({ params: { slug: character.slug } }));
}

const character = getCharacterBySlug(Astro.params.slug ?? '');
if (!character) throw new Error(`Character not found: ${Astro.params.slug}`);
---
<CharacterLayout character={character} />
