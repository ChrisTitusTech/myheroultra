---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import CharacterLayout from '../../layouts/CharacterLayout.astro';
import { characters } from '../../data/characters';
import type { CharacterRecord } from '../../data/characters';

export async function getStaticPaths() {
  const guides = await getCollection('guides', ({ data }) => !data.draft);

  return characters.map((character) => ({
    params: { slug: character.slug },
    props: {
      character,
      relatedGuides: guides.filter((guide) => guide.data.characterId === character.id),
    },
  }));
}

interface Props {
  character: CharacterRecord;
  relatedGuides: CollectionEntry<'guides'>[];
}

const { character, relatedGuides } = Astro.props;
---
<CharacterLayout character={character} relatedGuides={relatedGuides} />
