---
import { getCollection } from 'astro:content';
import GuideCard from '../../components/GuideCard.astro';
import { guideCategoryLabels, sortGuides } from '../../data/guides';
import BaseLayout from '../../layouts/BaseLayout.astro';

const guides = sortGuides(await getCollection('guides', ({ data }) => !data.draft));
const categories = [...new Set(guides.map((guide) => guide.data.category))];
---
<BaseLayout
  title="Guides | Ultra Rumble Field Notes"
  description="Browse My Hero Ultra Rumble beginner, character, combo, unlock, and currency guides."
>
  <header class="page-heading">
    <p class="eyebrow">Player resources</p>
    <h1>Guides</h1>
    <p>Practical routes, unlock advice, and character strategy written for quick reference.</p>
    <div class="guide-difficulty-legend" aria-label="Filter guides by difficulty">
      <button
        class="guide-difficulty guide-difficulty--beginner guide-difficulty-filter"
        type="button"
        data-guide-filter="beginner"
        aria-pressed="false"
      >
        Beginner
      </button>
      <button
        class="guide-difficulty guide-difficulty--intermediate guide-difficulty-filter"
        type="button"
        data-guide-filter="intermediate"
        aria-pressed="false"
      >
        Intermediate
      </button>
      <button
        class="guide-difficulty guide-difficulty--expert guide-difficulty-filter"
        type="button"
        data-guide-filter="expert"
        aria-pressed="false"
      >
        Expert
      </button>
    </div>
  </header>

  {guides.length > 0 ? (
    <>
      <div class="guide-filter-status">
        <p class="result-count" aria-live="polite">
          Showing <strong data-guide-result-count>{guides.length}</strong> guides
        </p>
        <button class="reset-button" type="button" data-guide-filter-reset hidden>
          Show all guides
        </button>
      </div>
      <ul class="guide-category-list" aria-label="Available guide categories">
        {categories.map((category) => <li>{guideCategoryLabels[category]}</li>)}
      </ul>
      <section class="guide-grid" aria-label="Published guides">
        {guides.map((guide) => <GuideCard guide={guide} />)}
      </section>
      <section class="empty-state guide-filter-empty" data-guide-filter-empty hidden>
        <h2>No guides at this difficulty</h2>
        <p>Choose another difficulty or show the full guide library.</p>
        <button class="button" type="button" data-guide-filter-reset>Show all guides</button>
      </section>
    </>
  ) : (
    <section class="empty-state">
      <h2>No published guides found</h2>
      <p>The character field guides are still available while the guide library is restored.</p>
      <a class="button" href="/characters">Browse characters</a>
    </section>
  )}
</BaseLayout>

<script>
  const filterButtons = [...document.querySelectorAll<HTMLButtonElement>('[data-guide-filter]')];
  const guideCards = [...document.querySelectorAll<HTMLElement>('[data-guide-difficulty]')];
  const resetButtons = [...document.querySelectorAll<HTMLButtonElement>('[data-guide-filter-reset]')];
  const resultCount = document.querySelector<HTMLElement>('[data-guide-result-count]');
  const emptyState = document.querySelector<HTMLElement>('[data-guide-filter-empty]');

  let activeDifficulty: string | null = null;

  const updateGuideFilter = (difficulty: string | null) => {
    activeDifficulty = difficulty;
    let visibleCount = 0;

    guideCards.forEach((card) => {
      const visible = difficulty === null || card.dataset.guideDifficulty === difficulty;
      card.hidden = !visible;
      if (visible) visibleCount += 1;
    });

    filterButtons.forEach((button) => {
      button.setAttribute('aria-pressed', String(button.dataset.guideFilter === difficulty));
    });

    resetButtons.forEach((button) => {
      button.hidden = difficulty === null;
    });

    if (resultCount) resultCount.textContent = String(visibleCount);
    if (emptyState) emptyState.hidden = visibleCount > 0;
  };

  filterButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const difficulty = button.dataset.guideFilter ?? null;
      updateGuideFilter(activeDifficulty === difficulty ? null : difficulty);
    });
  });

  resetButtons.forEach((button) => {
    button.addEventListener('click', () => updateGuideFilter(null));
  });
</script>
