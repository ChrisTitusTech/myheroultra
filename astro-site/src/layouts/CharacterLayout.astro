---
import type { CollectionEntry } from 'astro:content';
import CharacterHero from '../components/CharacterHero.astro';
import GuideCard from '../components/GuideCard.astro';
import SkillGrid from '../components/SkillGrid.astro';
import SourceBadge from '../components/SourceBadge.astro';
import StatBar from '../components/StatBar.astro';
import type { CharacterRecord } from '../data/characters';
import BaseLayout from './BaseLayout.astro';

interface Props {
  character: CharacterRecord;
  relatedGuides?: CollectionEntry<'guides'>[];
}

const { character, relatedGuides = [] } = Astro.props;
const canonicalUrl = new URL(`/characters/${character.slug}/`, Astro.site);
const structuredData = [
  {
    '@type': 'WebPage',
    name: `${character.name} Guide`,
    description: character.summary,
    url: canonicalUrl.href,
    about: {
      '@type': 'Thing',
      name: character.name,
      description: character.summary,
    },
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Characters',
        item: new URL('/characters/', Astro.site).href,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: character.name,
        item: canonicalUrl.href,
      },
    ],
  },
];
---

<BaseLayout
  title={`${character.name} Guide | Ultra Rumble Field Notes`}
  description={`${character.summary} View ${character.name} skills, ratings, strengths, weaknesses, and beginner notes.`}
  ogType="article"
  structuredData={structuredData}
>
  <article class="character-page">
    <CharacterHero character={character} />

    <div class="character-page__grid">
      <div class="character-page__main">
        <section class="content-section" aria-labelledby="playstyle-heading">
          <p class="section-kicker">Game plan</p>
          <h2 id="playstyle-heading">How {character.name} plays</h2>
          <p class="section-lede">{character.playstyle}</p>
        </section>

        <section class="content-section" aria-labelledby="skills-heading">
          <p class="section-kicker">Kit overview</p>
          <h2 id="skills-heading">Skills and special actions</h2>
          <SkillGrid skills={character.skills} />
        </section>

        <section class="content-section split-section" aria-label="Strengths and weaknesses">
          <div>
            <p class="section-kicker">What works</p>
            <h2>Strengths</h2>
            <ul class="check-list">
              {character.strengths.map((strength) => <li>{strength}</li>)}
            </ul>
          </div>
          <div>
            <p class="section-kicker">Watch for</p>
            <h2>Weaknesses</h2>
            <ul class="warning-list">
              {character.weaknesses.map((weakness) => <li>{weakness}</li>)}
            </ul>
          </div>
        </section>

        <section class="content-section" aria-labelledby="beginner-heading">
          <p class="section-kicker">First matches</p>
          <h2 id="beginner-heading">Beginner notes</h2>
          <ol class="numbered-notes">
            {character.beginnerNotes.map((note) => <li>{note}</li>)}
          </ol>
        </section>
      </div>

      <aside class="character-page__sidebar" aria-label={`${character.name} quick reference`}>
        <section class="stat-panel">
          <p class="section-kicker">Quick read</p>
          <h2>Guide ratings</h2>
          <p class="panel-note">HP is sourced game data. The 1–10 ratings are editorial guide scores.</p>
          <div class="hp-stat"><span>HP</span><strong>{character.stats.hp}</strong></div>
          <StatBar label="Damage" value={character.stats.damage} />
          <StatBar label="Mobility" value={character.stats.mobility} />
          <StatBar label="Range" value={character.stats.range} />
          <StatBar label="Team utility" value={character.stats.teamUtility} />
          <StatBar label="Difficulty" value={character.stats.difficulty} />
        </section>

        <section class="level-panel">
          <p class="section-kicker">Suggested start</p>
          <h2>Level-up order</h2>
          <ol>
            {character.recommendedLevelOrder.map((step) => <li>{step}</li>)}
          </ol>
          <p class="panel-note">Editorial baseline; adapt it to team composition and balance changes.</p>
        </section>

        <SourceBadge source={character.source} needsVerification={character.needsVerification} />
      </aside>
    </div>
  </article>

  {relatedGuides.length > 0 && (
    <section class="related-guides" aria-labelledby="character-related-guides-heading">
      <p class="section-kicker">Character resources</p>
      <h2 id="character-related-guides-heading">More {character.name} guides</h2>
      <div class="guide-grid">
        {relatedGuides.map((guide) => <GuideCard guide={guide} compact headingLevel="h3" />)}
      </div>
    </section>
  )}
</BaseLayout>
